<link rel="stylesheet" href="/css/style.css">
<title>Chat</title>

<div class="offcanvas offcanvas-start" tabindex="-1" id="chats" aria-labelledby="chatsLabel" style="user-select: none;">
    <div class="offcanvas-header">
        <h2 class="offcanvas-title" id="chatsLabel">Seus contatos</h2>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
       
            
            <button class="btn btn-success" id="newChat"><h4 style="font-size: calc(0.8vw + 10pt);">Novo grupo</h4></button>
            <button class="btn btn-danger" onclick="deslog()"><h4 style="font-size: calc(0.8vw + 10pt);">Deslogar</h4></button>
            
            <br> <br>
            {{!-- <div style="width: fit-content;">
                <h4>Ping</h4>
                <input id='ping' type="number" class="form-control form-control-sm" placeholder="5 - 100">
            </div>
             --}}

            <hr>

            {{#each chats}}
            <div style="max-width: 90%;" class="btn btn-secondary" id="{{id}}" data-bs-dismiss="offcanvas" onclick="changeChat(this.id, this.innerHTML, this.children);">
                {{#if name}}
                    <h4 style="display: inline-block; font-size: calc(1vw + 5pt);"> {{name}} </h4>
                {{else}}
                {{#each group}}
                    <h4 style="text-decoration: {{text}}; font-size: calc(1vw + 5pt); display: inline-block;"> {{name}} </h4>
                {{/each}}
                {{/if}}
                
                {{#each group}}
                    <h4 style="text-decoration: {{text}}; font-size: calc(1vw + 5pt); display: inline-block; visibility: hidden; width: 0px; height: 0px; position: absolute;" is_admin="{{is_admin}}" id="{{id}}">
                        {{name}}
                    </h4>
                {{/each}}
            </div> 
            <span id="chatDate{{id}}" style="width: 0px; height: 0px; visibility: hidden; position: absolute;">{{date}}</span>
            <br> <br>

            {{/each}}
        
    </div>
</div>




<div class="offcanvas offcanvas-start" tabindex="-1" id="detail" aria-labelledby="detailLabel">
    <div class="offcanvas-header">
        <h2 class="offcanvas-title" id="detailLabel">Detalhes do grupo</h2>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <div class="offcanvas-body" id="this_chat">
        

        <div id='onlyAdm' style="visibility: hidden;">

            <h4 id="add">Adicionar à</h4>
            <hr>

            
            <div class="input-group mb-3">
                <span class="input-group-text btn-outline-secondary" style="cursor: pointer; border: 0px;" onclick="nameGroup(document.querySelector('#groupName').value)">Alterar nome</span>
                <input type="text" class="form-control" id="groupName" placeholder="Reiniciar">
            </div>

            <div class="input-group">
                <input type="text" class="form-control" id="newChatPeople" autocomplete="off">
                <button class="btn btn-success" id="okAdd"><h7>Adicionar</h7></button> 
                <button class="btn btn-warning" id="admAdd"><h7>Alternar adm</h7></button>
                <button class="btn btn-danger" id="delPpl"><h7>	&#128465; </h7></button>
            </div>
            <br>

            <div id="sugest"></div>

        </div>
        
        <div class="all" style="visibility: hidden; width: 0; height: 0;">
            {{#each all}}
                {{ppl}},
            {{/each}}
        </div>

        <hr>

        <div class="peopleOnGroup">
            <h2>Escolha uma conversa</h2>
        </div>
        <br>
        <button class="btn btn-danger" id="delMe">Sair do grupo</button>

    </div>

</div>

<div class="ceil">
    <div class="bottom_ceil">
        
        <button style="border: 1px solid black; margin-top: 1%; max-width: 25%;" class="btn btn-primary" type="button" id="ctt" data-bs-toggle="offcanvas" data-bs-target="#detail" aria-controls="offcanvasExample">
            <h4>Mude o contato</h4>
        </button> 
        
        <br>
        
    </div>
</div>

<div class="flex">
    <div class="msg-container">

        <img src="/img/lines.png" id="callOffCanvas1" width="3.76%" style="position: absolute; margin: 15px;" data-bs-toggle="offcanvas" data-bs-target="#chats" aria-controls="chats">
        <div class="overflow">  
            <div id="msg_render"></div>
        </div>

        <div class="submit">
            
            <div class="input-group inpg" id="textVis">
                <textarea class="form-control text" id="text"></textarea>
                <button type="button" class="btn btn-success submit-text" id="submit">Enviar</button> <h1 id="goDown">&laquo;</h1>
            </div>      
            
            <form id="fileForm">
                <div class="mb-3 fileSize">
                    <input class="form-control form-control-sm" type="file" id="file">
                </div>
                <button id="fileBtn" class='btn btn-success btn-sm' type="submit">Ok</button>
            </form> 
            

        
        </div>
    </div>
</div>



<p id="reloadP" style="width: 0; height: 0; font-size: 0; position: absolute;">{{this_chat}}</p>




<script src="/js/script.js"></script>






